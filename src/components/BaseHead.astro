---
import "../styles/global.css";
import { SEO } from "astro-seo";
import { ClientRouter } from "astro:transitions";
import { supabase } from "@/db/supabase";
import { toOpenGraphImageUrl } from "@/utils/image-optimizer";

export interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  image?: string;
  /** Open Graph type, məs. post səhifələri üçün "article" */
  openGraphType?: string;
  keywords?: string;
  xHandle?: string;
  facebookHandle?: string;
  siteName?: string;
}

// Settings-dən məlumatları al
let settings: any = {};

try {
  const { data: settingsData } = await supabase
    .from("settings")
    .select("key, value");

  if (settingsData) {
    for (const setting of settingsData) {
      settings[setting.key] = setting.value;
    }
  }
} catch (error) {
  console.error("Settings yüklənərkən xəta:", error);
}

const {
  title = settings.site_title,
  description = settings.site_description,
  canonical: canonicalProp,
  image: imageProp,
  openGraphType = "website",
  keywords = settings.site_keywords,
  xHandle = settings.x_handle,
  facebookHandle = settings.facebook_handle,
  siteName = settings.site_title,
} = Astro.props;

const siteBase = Astro.site ?? Astro.url;
const canonical =
  typeof canonicalProp === "string" && canonicalProp.trim()
    ? canonicalProp.trim()
    : new URL(Astro.url.pathname, siteBase).href;

// Sosial şəbəkə scraper-ləri üçün: əvvəl `/api/image-optimize` qabığı varsa, daxildəki
// birbaşa şəkil URL-ini çıxarırıq (müxtəlif hallarda tutarlılıq üçün).
// WebP CDN faylları isə OG/Twitter üçün ayrıca JPEG endpoint-ə yönləndirilir
// (`toOpenGraphImageUrl`).
function resolveOgImage(raw: string): string {
  try {
    const parsed = new URL(raw, siteBase);
    if (parsed.pathname === "/api/image-optimize") {
      const inner = parsed.searchParams.get("url");
      if (inner) return inner;
    }
    return parsed.href;
  } catch {
    return raw;
  }
}

const siteOrigin = new URL(siteBase).origin;

const defaultResolved = resolveOgImage(
  settings.og_image || `${siteOrigin}/og-image.jpg`,
);
const resolvedOgSource =
  typeof imageProp === "string" && imageProp.trim()
    ? resolveOgImage(imageProp.trim())
    : defaultResolved;
const image = toOpenGraphImageUrl(resolvedOgSource, siteOrigin);
---

<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />

<SEO
  title={title}
  description={description}
  canonical={canonical}
  openGraph={{
    basic: {
      title: title,
      type: openGraphType,
      image: image,
      url: canonical,
    },
    optional: {
      description: description,
      siteName: siteName,
      locale: "az_AZ",
    },
    image: {
      alt: title,
    },
  }}
  twitter={{
    card: "summary_large_image",
    site: xHandle ? `@${xHandle}` : undefined,
    creator: xHandle ? `@${xHandle}` : undefined,
    title: title,
    description: description,
    image: image,
    imageAlt: title,
  }}
/>

<meta name="keywords" content={keywords} />
<meta name="author" content={siteName} />


<!-- Favicons -->
<link rel="icon" href="/favicon.ico" sizes="any" />
<link rel="shortcut icon" href="/favicon.ico" type="image/x-icon" />

<!-- Additional SEO -->
<meta name="googlebot" content="index, follow" />

<!-- Theme Color for Mobile Browsers -->
<meta name="theme-color" content="#ffffff" />

<!-- For IE -->
<meta http-equiv="X-UA-Compatible" content="IE=edge" />

<!-- Additional SEO Meta Tags -->
<meta name="language" content="Azerbaijani" />
<meta name="revisit-after" content="7 days" />
<meta name="distribution" content="global" />
<meta name="rating" content="general" />
<meta name="apple-mobile-web-app-capable" content="yes" />
<meta name="apple-mobile-web-app-status-bar-style" content="default" />
<meta name="apple-mobile-web-app-title" content={siteName} />

<!-- Mobile Optimization -->
<meta name="mobile-web-app-capable" content="yes" />
<meta name="format-detection" content="telephone=no" />
<!-- Preconnect for critical font origins -->
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link rel="preconnect" href="https://api.fontshare.com" />

<!-- Critical fonts preload -->
<link rel="preload" href="https://api.fontshare.com/v2/css?f[]=panchang@400,500,600&display=swap" as="style" />

<!-- Font stylesheets with display=swap and media=print trick -->
<link rel="stylesheet" href="https://api.fontshare.com/v2/css?f[]=panchang@200,300,400,500,600,700&f[]=bebas-neue@400&f[]=jet-brains-mono@1,2&display=swap" media="print" onload="this.media='all'" />
<noscript>
  <link rel="stylesheet" href="https://api.fontshare.com/v2/css?f[]=panchang@200,300,400,500,600,700&f[]=bebas-neue@400&f[]=jet-brains-mono@1,2&display=swap" />
</noscript>

<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Big+Shoulders:opsz,wght@10..72,100..900&family=Google+Sans+Code:ital,wght@0,300..800;1,300..800&display=swap" media="print" onload="this.media='all'" />
<noscript>
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Big+Shoulders:opsz,wght@10..72,100..900&family=Google+Sans+Code:ital,wght@0,300..800;1,300..800&display=swap" />
</noscript>

<!-- Inter font artıq lokal host edilir - global.css-də -->

<!-- Defer non-critical scripts -->
<script is:inline type="module" src="https://unpkg.com/ionicons@7.1.0/dist/ionicons/ionicons.esm.js" defer></script>
<script is:inline nomodule src="https://unpkg.com/ionicons@7.1.0/dist/ionicons/ionicons.js" defer></script>
<script is:inline src="https://unpkg.com/alpinejs@3.x.x/dist/cdn.min.js" defer></script>

<ClientRouter fallback="none" />

{settings.google_analytics_id && (
  <>
    <!-- Google tag (gtag.js) - Lazy loaded for better performance -->
    <script is:inline define:vars={{ gaId: settings.google_analytics_id }}>
      // GA-nı lazy load et - ilkin yükləməni yavaşlatmamaq üçün
      function loadGA() {
        if (window.gaLoaded) return;
        window.gaLoaded = true;
        
        var script = document.createElement('script');
        script.src = 'https://www.googletagmanager.com/gtag/js?id=' + gaId;
        script.async = true;
        document.head.appendChild(script);
        
        window.dataLayer = window.dataLayer || [];
        function gtag(){window.dataLayer.push(arguments);}
        window.gtag = gtag;
        gtag('js', new Date());
        gtag('config', gaId);
      }
      
      // İstifadəçi interaksiyası və ya idle vaxtında yüklə
      if ('requestIdleCallback' in window) {
        requestIdleCallback(loadGA, { timeout: 4000 });
      } else {
        setTimeout(loadGA, 2000);
      }
      
      // İstifadəçi interaksiyasında dərhal yüklə
      ['scroll', 'click', 'touchstart', 'keydown'].forEach(function(event) {
        document.addEventListener(event, loadGA, { once: true, passive: true });
      });
    </script>
  </>
)}

<script>
  import { initNavigationLoader } from '@/scripts/navigationLoader';
  initNavigationLoader();
</script>

<style is:global>
  @keyframes bump {
    0% {
      opacity: 0;
      transform: scale(1) translateX(200px);
    }
    50% {
      opacity: 0.5;
      transform: scale(1.1);
    }
    100% {
      opacity: 1;
      transform: scale(1) translateX(0);
    }
  }
</style>
 
