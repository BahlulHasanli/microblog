---
import { windowsVideos } from "@/data/windows-videos";
---

<section
  class="home-video-grid max-w-7xl mx-auto w-full px-4 sm:px-6 mt-6 sm:mt-8 mb-2"
  aria-labelledby="home-video-grid-title"
>
  <div
    class="mb-6 sm:mb-8 mx-auto flex w-full max-w-6xl flex-col gap-4 sm:flex-row sm:items-end sm:justify-between"
  >
    <h2
      class="text-3xl sm:text-4xl font-nouvelr-semibold text-slate-900 dark:text-base-50 m-0 tracking-tight"
    >
      Pəncərələr
    </h2>
    <a
      href="/windows"
      class="group/daha inline-flex w-fit items-center gap-1.5 rounded-full px-3 py-1.5 sm:px-4 sm:py-2 text-xs sm:text-sm font-medium font-nouvelr-semibold shrink-0 bg-base-100 dark:bg-base-900 text-base-700 dark:text-base-400 border border-transparent dark:border-base-800 hover:bg-base-200 dark:hover:bg-base-800 hover:text-base-900 dark:hover:text-base-100 transition-all"
    >
      Daha çox
      <svg
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 20 20"
        fill="currentColor"
        class="size-3.5 sm:size-4 translate-x-0 opacity-70 transition-[transform,opacity] duration-200 ease-out group-hover/daha:translate-x-1 group-hover/daha:opacity-100"
        aria-hidden="true"
      >
        <path
          fill-rule="evenodd"
          d="M3 10a.75.75 0 0 1 .75-.75h10.638L10.23 5.29a.75.75 0 1 1 1.04-1.08l5.5 5.25a.75.75 0 0 1 0 1.08l-5.5 5.25a.75.75 0 1 1-1.04-1.08l4.158-3.96H3.75A.75.75 0 0 1 3 10Z"
          clip-rule="evenodd"
        />
      </svg>
    </a>
  </div>

  <div
    class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-4"
    role="list"
  >
    {
      windowsVideos.map((video) => (
        <a
          href="/windows"
          role="listitem"
          class="group relative block cursor-pointer overflow-hidden rounded-lg outline-none focus-visible:ring-2 focus-visible:ring-slate-900 dark:focus-visible:ring-base-200 focus-visible:ring-offset-2 dark:focus-visible:ring-offset-base-950"
        >
          <div class="relative h-[min(70vh,420px)] w-full sm:h-[480px] lg:h-[500px]">
            <img
              src={video.thumbnail}
              alt={video.title}
              width="800"
              height="1000"
              loading="lazy"
              decoding="async"
              class="absolute inset-0 h-full w-full object-cover"
            />

            <div
              class="absolute inset-0 z-10 flex items-center justify-center bg-black/30 transition-all duration-200 ease-in-out group-hover:bg-black/50"
              aria-hidden="true"
            >
              <svg
                class="h-14 w-14 sm:h-16 sm:w-16 text-white"
                viewBox="0 0 24 24"
                fill="currentColor"
              >
                <path d="M7 4v16l13-8L7 4z" />
              </svg>
            </div>

            <div
              class="absolute bottom-0 left-0 right-0 z-20 rounded-b-lg bg-linear-to-t from-black/80 to-transparent p-4 text-white"
            >
              <div class="mb-1 text-sm text-white/95 font-nouvelr line-clamp-2">
                {video.category}
              </div>
              <h3 class="mb-2 text-base font-bold leading-snug font-nouvelr-semibold line-clamp-3 m-0">
                {video.title}
              </h3>
              <div class="text-sm text-zinc-300 font-nouvelr">{video.authorName}</div>
            </div>

            <div class="absolute bottom-4 right-4 z-30 rounded bg-black/60 px-2 py-1 text-sm text-white tabular-nums font-nouvelr">
              {video.duration}
            </div>
          </div>
        </a>
      ))
    }
  </div>
</section>
