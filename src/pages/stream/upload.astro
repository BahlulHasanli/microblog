---
import BaseLayout from "@/layouts/BaseLayout.astro";
import StreamVideoUploadForm from "@/components/stream/StreamVideoUploadForm.svelte";
import { isAuthenticated, getUserFromCookies } from "@/utils/auth";

if (!isAuthenticated(Astro.cookies)) {
  return Astro.redirect("/signin");
}

const user = await getUserFromCookies(Astro.cookies, Astro.redirect);
if (!user) {
  return Astro.redirect("/signin");
}

/** Müvəqqəti: yalnız admin (role_id === 1). Moderator/editor sonra açıla bilər. */
const isAdmin = user.role_id === 1;
if (!isAdmin) {
  return Astro.redirect("/");
}
---

<BaseLayout
  title="Video əlavə et"
  description="Pəncərələr üçün Bunny Stream: fayl yüklə və ya HLS playlist linki ilə qeydiyyat."
>
  <section class="py-8 sm:py-12 px-4">
    <StreamVideoUploadForm client:load />
  </section>
</BaseLayout>
