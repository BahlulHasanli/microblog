---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { isAuthenticated, getUserFromCookies } from "@/utils/auth";
import { isEditor } from "@/utils/roles";
import { buildWriterAnalyticsData } from "@/lib/build-writer-analytics-data";
import WriterAnalyticsTabs from "@/components/writer/WriterAnalyticsTabs";

export const prerender = false;

const isLoggedIn = isAuthenticated(Astro.cookies);

if (!isLoggedIn) {
  return Astro.redirect("/signin");
}

const user = await getUserFromCookies(Astro.cookies, Astro.redirect);

if (!user) {
  return Astro.redirect("/signin");
}

if (!isEditor(user.role_id)) {
  return Astro.redirect("/");
}

const analyticsData = await buildWriterAnalyticsData({ authorId: user.id });
---

<BaseLayout
  title="Analitika paneli"
  description="Məqalələrinizin oxunma və şərh statistikası."
>
  <div class="max-w-3xl mx-auto mt-6">
    <header class="mb-8 sm:mb-10">
      <p class="text-sm font-medium text-rose-600 dark:text-rose-400 mb-1">
        Müəllif üçün analitika paneli
      </p>
      <h1 class="text-2xl sm:text-3xl font-nouvelr font-bold text-base-900 dark:text-base-50 tracking-tight">
        Analitika
      </h1>
      <p class="mt-2 text-base text-base-600 dark:text-base-400 max-w-xl">
        Ümumi göstəricilər, məzmun, trend,
        bölmələr və məqalə siyahısı.
      </p>
    </header>

    <div class="mb-10">
      <WriterAnalyticsTabs
        data={analyticsData}
        client:only="react"
      />
    </div>
  </div>
</BaseLayout>
