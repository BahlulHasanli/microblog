---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { isAuthenticated, getUserFromCookies } from "@/utils/auth";
import ProfileHeader from "@/components/profile/ProfileHeader";
import ProfileTabs from "@/components/profile/ProfileTabs";
import { supabase } from "@/db/supabase";
import { formatISO } from "@/utils/date";

export const prerender = false;

const { username: usernameParam } = Astro.params;

// @ prefiksi məcburidir - profil səhifəsi identifikatorudur
if (!usernameParam?.startsWith("@")) {
  return Astro.redirect("/404");
}

// @ prefiksini sil (məs: @hasanli -> hasanli)
const username = usernameParam.slice(1);

// İstifadəçi məlumatlarını username ilə al
const { data: userData, error: userError } = await supabase
  .from("users") 
  .select("id, fullname, username, avatar, email")
  .eq("username", username)
  .single();

if (userError || !userData) {
  console.error("İstifadəçi tapılmadı:", userError);
  return Astro.redirect("/404");
}

const user = userData;

// Cari istifadəçini yoxla (giriş etmişsə)
const isLoggedIn = isAuthenticated(Astro.cookies);
let currentUser = null;
let isOwner = false;

if (isLoggedIn) {
  currentUser = await getUserFromCookies(Astro.cookies, Astro.redirect);
  // Profil sahibi ilə cari istifadəçini müqayisə et
  isOwner = currentUser?.id === user.id;
}

// İstifadəçinin postlarını al
const { data: postsData, error: postsError } = await supabase
  .from("posts")
  .select("*")
  .eq("author_id", user.id)
  .order("pub_date", { ascending: false });

if (postsError) {
  console.error('Postlar yüklənərkən xəta:', postsError);
}

// Məqalələr: qaralama deyil; qonaq üçün yalnız təsdiqlənmiş, sahib üçün həm gözləmədə olanlar
const publishedPostsData = (postsData || []).filter((post) => {
  if (post.is_draft === true) return false;
  if (isOwner) return true;
  return post.approved === true;
});

// Qaralama: yalnız profil sahibinə (client və server tərəfdə tək mənbə)
const draftPostsData = isOwner
  ? (postsData || []).filter((post) => post.is_draft === true)
  : [];

const mapPostRow = (
  post: (typeof postsData)[number],
  opts: { isDraft: boolean },
) => ({
  id: post.id,
  title: post.title,
  description: post.description,
  slug: post.slug,
  image: post.image_url || "",
  created_at: formatISO(post.pub_date),
  categories: post.categories || [],
  approved: post.approved || false,
  isDraft: opts.isDraft,
});

const posts = publishedPostsData.map((post) => mapPostRow(post, { isDraft: false }));
const draftPosts = draftPostsData.map((post) => mapPostRow(post, { isDraft: true }));
---

<BaseLayout>
  <div class="max-w-3xl mx-auto pt-4 sm:pt-6 md:pt-8 pb-8 sm:pb-12 md:pb-16 px-4 sm:px-0">
    <ProfileHeader 
      client:load 
      user={user}
      isOwner={isOwner}
    />
    
    <ProfileTabs 
      client:load 
      posts={posts || []}
      draftPosts={draftPosts}
      userId={user.id}
      isOwner={isOwner}
      currentUserId={currentUser?.id}
    />
  </div>
</BaseLayout>
